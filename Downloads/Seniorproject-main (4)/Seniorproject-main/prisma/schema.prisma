generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ── Existing table ──────────────────────────────────────────────────────────

model Listing {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  title       String
  category    String
  condition   String
  price       Float
  status      String   @default("available")
  description String
  images      Json     @default("[]")
  seller_name String?
  created_at  DateTime @default(now()) @db.Timestamptz
  open_to_offers  Boolean @default(false)

  conversations Conversation[]
  reports       Report[]
  reviews       Review[]

  transactions  Transaction[]

  @@map("listings")
  @@schema("public")
}

// ── Messaging ───────────────────────────────────────────────────────────────

model Conversation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id String?  @db.Uuid
  buyer_id   String   @db.Uuid
  seller_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz

  listing  Listing?  @relation(fields: [listing_id], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([listing_id, buyer_id, seller_id])
  @@map("conversations")
  @@schema("public")
}

model Message {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String   @db.Uuid
  sender_id       String   @db.Uuid
  content         String
  read            Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
  @@schema("public")
}

// ── Reporting ───────────────────────────────────────────────────────────────

model Report {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id  String   @db.Uuid
  reporter_id String   @db.Uuid
  reason      String
  details     String?
  status      String   @default("pending")
  created_at  DateTime @default(now()) @db.Timestamptz

  listing Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, reporter_id])
  @@map("reports")
  @@schema("public")
}

// ── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id        String   @db.Uuid
  reviewer_id       String   @db.Uuid
  seller_id         String   @db.Uuid
  reviewed_user_id  String @db.Uuid
  review_type       String @default("buyer_to_seller") // 'buyer_to_seller' | 'seller_to_buyer'
  reviewer_name     String @default("Anonymous")
  rating            Int
  comment           String?
  created_at        DateTime @default(now()) @db.Timestamptz

  listing Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@unique([listing_id, reviewer_id])
  @@index([reviewer_user_id])
  @@index([reviewer_id])
  @@map("reviews")
  @@schema("public")
}

// ── Profiles ─────────────────────────────────────────────────────────────────

model Profile {
  id                String   @id @db.Uuid
  full_name         String   @default("")
  phone             String?
  bio               String   @default("")
  major             String   @default("")
  graduation_year   Int?
  avatar_url        String?
  notify_messages   Boolean  @default(true)
  notify_listings   Boolean  @default(true)
  is_admin          Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("profiles")
  @@schema("public")
}

// ── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id    String   @db.Uuid
  seller_id     String   @db.Uuid
  buyer_id      String?  @db.Uuid
  price         Decimal  @db.Decimal(10, 2)
  title         String
  category      String   @default("")
  images        Json     @default("[]")
  status        String   @default("completed")
  completed_at  DateTime @default(now()) @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz

  listing Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@index([seller_id])
  @@index([buyer_id])
  @@map("transactions")
  @@schema("public")
}

// ── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  type        String
  title       String
  body        String   @default("")
  link        String?
  read        Boolean  @default(false)
  data        Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz

  @@index([user_id])
  @@index([user_id, read])
  @@index([created_at(sort: Desc)])
  @@map("notifications")
  @@schema("public")
}