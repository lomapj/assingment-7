---
import Layout from "../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import Button from "@/components/starwind/button/Button.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import Separator from "@/components/starwind/separator/Separator.astro";
import { Avatar, AvatarFallback } from "@/components/starwind/avatar";
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/starwind/tabs";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/starwind/table";
---

<Layout title="My Profile">
  <div class="bg-muted min-h-screen pb-16">
    <!-- Cover -->
    <div class="relative pb-8">
      <div class="h-60 bg-linear-to-br from-primary to-[#004d42] relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
        <div class="absolute inset-0 bg-linear-to-b from-transparent to-black/20"></div>
      </div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <Card class="shadow-xl -mt-20 relative z-10">
          <CardContent class="flex flex-col md:flex-row gap-6 md:gap-8 items-center md:items-start pt-6">
            <!-- Avatar -->
            <div class="relative shrink-0">
              <Avatar size="lg" variant="primary" class="w-35 h-35 text-5xl border-6 border-card shadow-lg"><AvatarFallback class="bg-primary text-primary-foreground" id="profileInitials">...</AvatarFallback></Avatar>
              <img id="profileAvatarImage" src="" alt="" class="hidden absolute inset-0 w-35 h-35 rounded-full object-cover border-6 border-card shadow-lg">
            </div>

            <div class="flex-1 text-center md:text-left">
              <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-2 mb-2">
                <h1 class="text-3xl font-extrabold text-foreground tracking-tight" id="profileName">Loading...</h1>
                <Button variant="outline" size="sm" class="gap-1.5" href="/edit-profile">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                  Edit Profile
                </Button>
              </div>

              <!-- Badges row: major, graduation year, FSC badge -->
              <div class="flex items-center gap-3 flex-wrap justify-center md:justify-start mb-3">
                <Badge variant="ghost" size="sm" class="text-primary bg-primary/10">Student @ FSC</Badge>
                <span id="profileMajorBadge" class="hidden">
                  <Badge variant="ghost" size="sm" class="text-foreground bg-muted-foreground/10" id="profileMajorText"></Badge>
                </span>
                <span id="profileGraduationBadge" class="hidden">
                  <Badge variant="ghost" size="sm" class="text-foreground bg-muted-foreground/10" id="profileGraduationText"></Badge>
                </span>
              </div>

              <p class="text-base text-muted-foreground leading-relaxed max-w-150 mb-4" id="profileEmail"></p>
              
              <!-- Bio -->
              <p class="text-sm text-muted-foreground leading-relaxed max-w-150 mb-2" id="profileBio"></p>

              <div class="flex items-center gap-6 justify-center md:justify-start">
                <div class="flex flex-col"><span class="text-xl font-extrabold text-foreground" id="listingCount">0</span><span class="text-xs font-semibold text-muted-foreground uppercase">Listings</span></div>
                <Separator orientation="vertical" class="h-8" />
                <div class="flex flex-col"><span class="text-xl font-extrabold text-foreground" id="soldCount">0</span><span class="text-xs font-semibold text-muted-foreground uppercase">Sold</span></div>
                <Separator orientation="vertical" class="h-8" />
                <div class="flex flex-col">
                  <span class="text-xl font-extrabold text-foreground flex items-center gap-1" id="ratingValue">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    —
                  </span>
                  <span class="text-xs font-semibold text-muted-foreground uppercase">Rating</span>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>

    <!-- Tabs Content -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 mt-8">
      <Tabs defaultValue="listings">
        <TabsList class="w-full justify-start bg-transparent border-b-2 border-border rounded-none mb-8 p-0">
          <TabsTrigger value="listings" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            My Listings
          </TabsTrigger>
          <TabsTrigger value="history" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            Sold Items
          </TabsTrigger>
          <TabsTrigger value="reviews">Reviews</TabsTrigger>
        </TabsList>

      <!-- Listings Panel -->
      <TabsContent value="listings" class="flex flex-col gap-6">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <h2 class="text-2xl font-extrabold text-foreground">Active Listings</h2>
          <Button variant="primary" size="sm" href="/post">+ New Listing</Button>
        </div>

        <!-- Loading skeleton -->
        <div id="listingsLoading" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {Array.from({ length: 4 }).map(() => (
            <div class="bg-card rounded-xl border border-border overflow-hidden animate-pulse">
              <div class="h-40 bg-muted"></div>
              <div class="p-4 space-y-2">
                <div class="h-4 w-16 bg-muted rounded"></div>
                <div class="h-5 w-3/4 bg-muted rounded"></div>
                <div class="h-6 w-20 bg-muted rounded"></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="listingsEmpty" class="hidden text-center py-12">
          <p class="text-muted-foreground mb-4">You haven't posted any listings yet.</p>
          <Button variant="primary" href="/post">Create Your First Listing</Button>
        </div>

        <!-- Listings grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 hidden" id="listingsGrid"></div>
      </TabsContent>

      <!-- Sold Items Panel -->
      <TabsContent value="history" class="flex flex-col gap-4">
        <h2 class="text-2xl font-extrabold text-foreground mb-2">Sold Items</h2>
        <div id="soldLoading" class="animate-pulse space-y-3">
          <div class="h-10 bg-muted rounded"></div>
          <div class="h-10 bg-muted rounded"></div>
          <div class="h-10 bg-muted rounded"></div>
        </div>
        <div id="soldEmpty" class="hidden text-center py-12">
          <p class="text-muted-foreground">No sold items yet.</p>
        </div>
        <div id="soldTable" class="hidden">
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Item</TableHead>
                <TableHead>Date</TableHead>
                <TableHead>Amount</TableHead>
                <TableHead>Status</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody id="soldTableBody">
            </TableBody>
          </Table>
        </div>
      </TabsContent>
      
        <TabsContent value="reviews" class="flex flex-col gap-4">
          <h2 class="text-2xl font-extrabold text-foreground mb-2">Reviews About Me</h2>
          <div id="reviewsLoading" class="animate-pulse space-y-3">
            <div class="h-20 bg-muted rounded-xl"></div>
            <div class="h-20 bg-muted rounded-xl"></div>
          </div>
          <div id="reviewsEmpty" class="hidden text-center py-12">
            <p class="text-muted-foreground">No reviews yet</p>
          </div>
          <div id="reviewsList" class="hidden space-y-4"></div>
          <div id="reviewsViewAll" class="hidden text-center mt-2">
            <a id="viewAllReviewsLink" href="/reviews" class="text-sm font-semibold text-primary hover:underline"> View all reviews</a>
          </div>
        </TabsContent>
      </Tabs>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from "../lib/supabase";
  import { fetchUserListings, deleteListing, updateListing, fetchUserRating, fetchUserReviews, timeAgo, type Listing, type Review } from "../lib/api";

  const CATEGORY_GRADIENTS: Record<string, string> = {
    Books: "linear-gradient(135deg,#2d6a4f,#52b788)",
    Electronics: "linear-gradient(135deg,#1e3c72,#2a5298)",
    Furniture: "linear-gradient(135deg,#a0522d,#cd853f)",
    Clothing: "linear-gradient(135deg,#457b9d,#1d3557)",
    Misc: "linear-gradient(135deg,#ef476f,#f78c6b)",
  };

  const CATEGORY_ICONS: Record<string, string> = {
    Books: "\u{1F4D7}",
    Electronics: "\u{1F4BB}",
    Furniture: "\u{1FA91}",
    Clothing: "\u{1F9E5}",
    Misc: "\u{1F4E6}",
  };

  async function loadProfile() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;
    
    const { data: profile } = await supabase
      .from("profiles")
      .select("*")
      .eq("id", user.id)
      .single();

    const meta = user.user_metadata;
    const fullName = profile?.full_name || meta?.full_name || user.email || "User";
    const initials = fullName.split(" ").map((w: string) => w[0]).join("").toUpperCase().slice(0, 2) || "U";

    document.getElementById("profileName")!.textContent = fullName;
    document.getElementById("profileInitials")!.textContent = initials;
    document.getElementById("profileEmail")!.textContent = user.email || "";
    
    if (profile?.avatar_url) {
      const avatarImage = document.getElementById("profileAvatarImage") as HTMLImageElement;
      avatarImage.src = profile.avatar_url;
      avatarImage.alt = fullName;
      avatarImage.classList.remove("hidden");
      document.getElementById("profileInitials")!.classList.add("hidden");
    }
    
    if (profile?.bio && profile.bio.trim()) {
      const bioElement = document.getElementById("profileBio")!;
      bioElement.textContent = profile.bio;
      bioElement.classList.remove("hidden");
    }
    
    if (profile?.major && profile.major.trim()) {
      document.getElementById("profileMajorText")!.textContent = profile.major;
      document.getElementById("profileMajorBadge")!.classList.remove("hidden");
    }
    
    if (profile?.graduation_year) {
      document.getElementById("profileGraduationText")!.textContent = `Class of ${profile.graduation_year}`;
      document.getElementById("profileGraduationBadge")!.classList.remove("hidden");
    }

    // Fetch and display seller rating
    try {
      const rating = await fetchUserRating(user.id);
      const ratingEl = document.getElementById("ratingValue");
      if (ratingEl) {
        ratingEl.innerHTML = rating.count > 0
          ? `<a href="/reviews?id=${user.id}" class="inline-flex items-center gap-1 hover:underline"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>${rating.average} <span class="text-muted-foreground text-xs">(${rating.count})</span></a>`
          : `<span class="text-muted-foreground">&mdash;</span>`;
      }
    }
    catch (err) {
      console.error("Failed to load user rating:", err);
    }
    
    // Load reviews for the Reviews tab
    try {
      const reviews = await fetchUserReviews(user.id);
      document.getElementById("reviewsLoading")!.classList.add("hidden");
      
      if (reviews.length === 0) {
        document.getElementById("reviewsEmpty")!.classList.remove("hidden");
      }
      else {
        const reviewsList = document.getElementById("reviewsList")!;
        reviewsList.classList.remove("hidden");
        reviewsList.innerHTML = reviews.slice(0, 5).map((r: Review) => {
          const typeLabel = r.review_type === "buyer_to_seller"
            ? `<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-blue-500/10 text-blue-600 border border-blue-200">Buyer \u2192 Seller</span>`
            : `<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-emerald-500/10 text-emerald-600 border border-emerald-200">Seller \u2192 Buyer</span>`;
          const stars = "\u2605".repeat(Math.floor(r.rating)) + "\u2606".repeat(5 - Math.floor(r.rating));
          const reviewerInitials = (r.reviewer_name || "?").split(" ").map((w: string) => w[0]).join("").toUpperCase().slice(0, 2);
          const timeAgoStr = timeAgo(r.created_at);
          
          return `
            <div class="p-4 rounded-xl border border-border bg-card">
              <div class="flex items-start justify-between mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary">${reviewerInitials}</div>
                  <div>
                    <span class="text-sm font-bold text-foreground">${r.reviewer_name || "Anonymous"}</span>
                    <span class="text-xs text-muted-foreground ml-2">${timeAgoStr}</span>
                  </div>
                </div>
                ${typeLabel}
              </div>
              <div class="text-amber-400 text-sm mb-1">${stars}</div>
              ${r.comment ? `<p class="text-sm text-muted-foreground">${r.comment}</p>` : ""}
            </div>
          `;
        }).join("");
        
        if (reviews.length > 5) {
          const viewAll = document.getElementById("reviewsViewAll")!;
          viewAll.classList.remove("hidden");
          document.getElementById("viewAllReviewsLink")!.setAttribute("href", `/reviews?id=${user.id}`);
        }
      }
    } catch (err) {
      console.error("Failed to load reviews:", err);
      document.getElementById("reviewsLoading")!.classList.add("hidden");
    }

    try {
      const listings = await fetchUserListings(user.id);
      const active = listings.filter((l) => l.status !== "sold");
      const sold = listings.filter((l) => l.status === "sold");

      document.getElementById("listingCount")!.textContent = active.length.toString();
      document.getElementById("soldCount")!.textContent = sold.length.toString();

      // Render active listings
      const loadingEl = document.getElementById("listingsLoading")!;
      const emptyEl = document.getElementById("listingsEmpty")!;
      const gridEl = document.getElementById("listingsGrid")!;
      loadingEl.classList.add("hidden");

      if (active.length === 0) {
        emptyEl.classList.remove("hidden");
      } else {
        gridEl.classList.remove("hidden");
        gridEl.innerHTML = active.map((item) => renderListingCard(item)).join("");
        attachCardHandlers(gridEl);
      }

      // Render sold items
      const soldLoading = document.getElementById("soldLoading")!;
      const soldEmpty = document.getElementById("soldEmpty")!;
      const soldTable = document.getElementById("soldTable")!;
      const soldTableBody = document.getElementById("soldTableBody")!;
      soldLoading.classList.add("hidden");

      if (sold.length === 0) {
        soldEmpty.classList.remove("hidden");
      } else {
        soldTable.classList.remove("hidden");
        soldTableBody.innerHTML = sold.map((item) => `
          <tr class="border-b border-border">
            <td class="p-3 font-bold text-foreground">${item.title}</td>
            <td class="p-3 text-muted-foreground">${new Date(item.created_at).toLocaleDateString()}</td>
            <td class="p-3 font-bold text-primary">$${item.price.toFixed(2)}</td>
            <td class="p-3"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold border border-green-500 text-green-600">Sold</span></td>
          </tr>
        `).join("");
      }
    } catch (err) {
      console.error("Failed to load listings:", err);
      document.getElementById("listingsLoading")!.classList.add("hidden");
      document.getElementById("listingsEmpty")!.classList.remove("hidden");
    }
  }

  function renderListingCard(item: Listing): string {
    const gradient = CATEGORY_GRADIENTS[item.category] || "linear-gradient(135deg,#6b7280,#9ca3af)";
    const icon = CATEGORY_ICONS[item.category] || "\u{1F4E6}";
    const hasImage = item.images && item.images.length > 0;

    return `
      <div class="bg-card rounded-xl border border-border overflow-hidden hover:-translate-y-1 hover:shadow-md transition-all" data-listing-id="${item.id}">
        <a href="/item?id=${item.id}" class="block">
          <div class="h-40 flex items-center justify-center relative" style="background: ${gradient}">
            ${hasImage
              ? `<img src="${item.images[0]}" alt="${item.title}" class="w-full h-full object-cover" />`
              : `<span class="text-5xl drop-shadow-md">${icon}</span>`
            }
            ${item.price === 0 && item.status === "available" ? `<span class="absolute top-2 left-2 z-10 inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-extrabold uppercase tracking-wide bg-teal-500 text-white shadow-sm">🎁 Free</span>` : ""}
            ${item.status === "pending" ? `<div class="absolute inset-0 bg-foreground/40 flex items-center justify-center text-white font-extrabold text-lg tracking-widest">PENDING</div>` : ""}
          </div>
        </a>
        <div class="p-4 flex justify-between items-end">
          <a href="/item?id=${item.id}" class="flex flex-col gap-0.5 no-underline text-inherit">
            <span class="text-xs font-bold text-muted-foreground uppercase">${item.category}</span>
            <h3 class="text-base font-extrabold text-foreground">${item.title}</h3>
            <span class="text-base font-extrabold ${item.price === 0 ? 'text-teal-600' : 'text-primary'}">${item.price === 0 ? 'FREE' : '$' + item.price.toFixed(2)}</span>
          </a>
          <div class="flex gap-1.5">
            <a href="/post?edit=${item.id}" class="w-10 h-10 rounded-lg border border-border bg-card flex items-center justify-center text-muted-foreground hover:text-primary hover:border-primary transition-colors" title="Edit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </a>
            <button class="mark-sold-btn w-10 h-10 rounded-lg border border-border bg-card flex items-center justify-center text-muted-foreground hover:text-green-600 hover:border-green-600 transition-colors" title="Mark as Sold" data-id="${item.id}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button class="delete-btn w-10 h-10 rounded-lg border border-border bg-card flex items-center justify-center text-muted-foreground hover:text-error hover:border-error transition-colors" title="Delete" data-id="${item.id}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg>
            </button>
          </div>
        </div>
      </div>
    `;
  }

  function attachCardHandlers(container: HTMLElement) {
    container.querySelectorAll<HTMLButtonElement>(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;
        if (!id || !confirm("Delete this listing? This cannot be undone.")) return;
        btn.disabled = true;
        try {
          await deleteListing(id);
          const card = btn.closest("[data-listing-id]");
          card?.remove();
          // Update count
          const remaining = container.querySelectorAll("[data-listing-id]").length;
          document.getElementById("listingCount")!.textContent = remaining.toString();
          if (remaining === 0) {
            container.classList.add("hidden");
            document.getElementById("listingsEmpty")!.classList.remove("hidden");
          }
        } catch (err) {
          alert("Failed to delete listing.");
          btn.disabled = false;
        }
      });
    });

    container.querySelectorAll<HTMLButtonElement>(".mark-sold-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;
        if (!id || !confirm("Mark this listing as sold?")) return;
        btn.disabled = true;
        try {
          await updateListing(id, { status: "sold" });
          // Reload to reflect changes
          window.location.reload();
        } catch (err) {
          alert("Failed to update listing.");
          btn.disabled = false;
        }
      });
    });
  }

  loadProfile();
</script>
