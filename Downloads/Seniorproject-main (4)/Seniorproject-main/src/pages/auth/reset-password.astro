---
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/starwind/card";
import Button from "@/components/starwind/button/Button.astro";
import Label from "@/components/starwind/label/Label.astro";
import Input from "@/components/starwind/input/Input.astro";
import { Alert, AlertDescription } from "@/components/starwind/alert";
---

<Layout title="Set New Password" authLayout={true} showFooter={true}>
  <div class="min-h-[calc(100vh-80px)] flex items-center justify-center p-4 sm:p-8 bg-muted">
    <div class="w-full max-w-110">

      <!-- Enter the code from email -->
      <Card class="shadow-xl mb-6" id="codeCard">
        <CardHeader class="text-center pb-2">
          <CardTitle class="text-2xl font-extrabold tracking-tight">Check Your Email</CardTitle>
          <CardDescription>Enter the reset code we sent to your @farmingdale.edu inbox</CardDescription>
        </CardHeader>
        <CardContent>
          <Alert id="codeErrorBanner" variant="error" class="hidden mb-4">
            <AlertDescription id="codeErrorText" class="text-sm font-medium"></AlertDescription>
          </Alert>

          <form class="flex flex-col" id="codeForm" novalidate>
            <div class="space-y-1.5 mb-4">
              <Label for="code">Reset Code</Label>
              <Input id="code" type="text" placeholder="Paste your reset code" autocomplete="off" required />
              <span class="text-xs text-muted-foreground">Check your spam folder if you don't see it</span>
            </div>

            <Button variant="primary" type="submit" class="w-full mt-2" id="codeSubmitBtn">Verify Code</Button>

            <p class="text-center text-sm text-muted-foreground mt-4">
              <a href="/forgot-password" class="text-primary font-bold hover:underline">Resend code</a>
            </p>
          </form>
        </CardContent>
      </Card>

      <!-- Set new password -->
      <Card class="shadow-xl mb-6 hidden" id="passwordCard">
        <CardHeader class="text-center pb-2">
          <CardTitle class="text-2xl font-extrabold tracking-tight">Set New Password</CardTitle>
          <CardDescription>Choose a strong new password for your account</CardDescription>
        </CardHeader>
        <CardContent>
          <Alert id="pwErrorBanner" variant="error" class="hidden mb-4">
            <AlertDescription id="pwErrorText" class="text-sm font-medium"></AlertDescription>
          </Alert>

          <form class="flex flex-col" id="passwordForm" novalidate>
            <div class="space-y-1.5 mb-4">
              <Label for="password">New Password</Label>
              <div class="relative">
                <Input id="password" type="password" placeholder="••••••••" autocomplete="new-password" class="pr-12" required />
                <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors p-1" id="togglePw" aria-label="Toggle password visibility">
                  <svg id="eyeOpen" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                  <svg id="eyeOff" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path>
                    <line x1="1" y1="1" x2="23" y2="23"></line>
                  </svg>
                </button>
              </div>
            </div>

            <div class="space-y-1.5 mb-4">
              <Label for="confirmPassword">Confirm New Password</Label>
              <Input id="confirmPassword" type="password" placeholder="Re-enter your new password" autocomplete="new-password" required />
            </div>

            <Button variant="primary" type="submit" class="w-full mt-2" id="pwSubmitBtn">Update Password</Button>
          </form>
        </CardContent>
      </Card>

    </div>
  </div>
</Layout>

<script>
  import { supabase } from "../../lib/supabase";

  const email = new URLSearchParams(window.location.search).get("email") || "";

  const codeCard = document.getElementById("codeCard") as HTMLElement;
  const passwordCard = document.getElementById("passwordCard") as HTMLElement;

  // Verify the reset code
  const form = document.getElementById("codeForm") as HTMLFormElement;
  const errorBanner = document.getElementById("codeErrorBanner") as HTMLElement;
  const errorText = document.getElementById("codeErrorText") as HTMLElement;
  const submitBtn = document.getElementById("codeSubmitBtn") as HTMLButtonElement;

  function showError(msg: string) {
    errorText.textContent = msg;
    errorBanner.classList.remove("hidden");
  }

  function hideError() {
    errorBanner.classList.add("hidden");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();

    const token = (document.getElementById("code") as HTMLInputElement).value.trim();
    if (!token) { showError("Please enter the reset code from your email."); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = "Verifying...";

    const { error } = await supabase.auth.verifyOtp({ email, token, type: "recovery" });

    if (error) {
      showError("Invalid or expired code. Please request a new one.");
      submitBtn.disabled = false;
      submitBtn.textContent = "Verify Code";
      return;
    }

    codeCard.classList.add("hidden");
    passwordCard.classList.remove("hidden");
  });

  // Set new password
  const passwordForm = document.getElementById("passwordForm") as HTMLFormElement;
  const pwErrorBanner = document.getElementById("pwErrorBanner") as HTMLElement;
  const pwErrorText = document.getElementById("pwErrorText") as HTMLElement;
  const pwSubmitBtn = document.getElementById("pwSubmitBtn") as HTMLButtonElement;

  // Toggle password visibility
  const toggleBtn = document.getElementById("togglePw");
  const pwInput = document.getElementById("password") as HTMLInputElement | null;
  const eyeOpen = document.getElementById("eyeOpen") as HTMLElement | null;
  const eyeOff = document.getElementById("eyeOff") as HTMLElement | null;

  toggleBtn?.addEventListener("click", () => {
    if (!pwInput) return;
    const showing = pwInput.type === "text";
    pwInput.type = showing ? "password" : "text";
    if (eyeOpen) eyeOpen.style.display = showing ? "" : "none";
    if (eyeOff) eyeOff.style.display = showing ? "none" : "";
  });

  passwordForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    pwErrorBanner.classList.add("hidden");

    const password = (document.getElementById("password") as HTMLInputElement).value;
    const confirmPassword = (document.getElementById("confirmPassword") as HTMLInputElement).value;

    if (!password) { pwErrorText.textContent = "Please enter a new password."; pwErrorBanner.classList.remove("hidden"); return; }
    if (password.length < 6) { pwErrorText.textContent = "Password must be at least 6 characters."; pwErrorBanner.classList.remove("hidden"); return; }
    if (password !== confirmPassword) { pwErrorText.textContent = "Passwords do not match."; pwErrorBanner.classList.remove("hidden"); return; }

    pwSubmitBtn.disabled = true;
    pwSubmitBtn.textContent = "Updating...";

    const { error } = await supabase.auth.updateUser({ password });

    if (error) {
      pwErrorText.textContent = error.message;
      pwErrorBanner.classList.remove("hidden");
      pwSubmitBtn.disabled = false;
      pwSubmitBtn.textContent = "Update Password";
      return;
    }

    window.location.href = "/login?reset=success";
  });
</script>
