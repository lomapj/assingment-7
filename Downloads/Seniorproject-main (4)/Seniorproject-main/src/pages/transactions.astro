---
import Layout from "../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import Button from "@/components/starwind/button/Button.astro";
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/starwind/tabs";
import { Table, TableHeader, TableBody, TableRow, TableHead, TableCell } from "@/components/starwind/table";
import Badge from "@/components/starwind/badge/Badge.astro";
---

<Layout title="Transaction History">
    <div class="bg-muted min-h-screen pb-16">
        <div class="mx-auto max-w-5xl px-6 lg:px-8 pt-8">

            <!-- Page Header -->
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
                <div>
                    <h1 class="text-3xl font-extrabold text-foreground tracking-tight">Transaction History</h1>
                    <p class="text-sm text-muted-foreground mt-1">View your purchases and sales</p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="flex items-center gap-4 text-sm">
                        <div class="text-center">
                            <p class="text-2xl font-extrabold text-foreground" id="totalSpent">$0</p>
                            <p class="text-xs text-muted-foreground font-semibold uppercase tracking-wide">Total Spent</p>
                        </div>
                        <div class="w-px h-10 bg-border"></div>
                        <div class="text-center">
                            <p class="text-2xl font-extrabold text-primary" id="totalEarned">$0</p>
                            <p class="text-xs text-muted-foreground font-semibold uppercase tracking-wide">Total Earned</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loading State -->
            <div id="loadingState" class="space-y-4">
                <div class="h-12 bg-card border border-border rounded-lg animate-pulse"></div>
                <div class="h-64 bg-card border border-border rounded-xl animate-pulse"></div>
            </div>

            <!-- Empty State -->
            <div id="emptyState" class="hidden text-center py-20">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-muted-foreground/50 mb-4">
                    <rect x="2" y="5" width="20" height="14" rx="2" />
                    <line x1="2" y1="10" x2="22" y2="10" />
                </svg>
                <h2 class="text-xl font-bold text-foreground mb-2">No transactions yet</h2>
                <p class="text-muted-foreground mb-6">Your purchase and sale history will appear here once you complete a transaction.</p>
                <Button variant="primary" href="/marketplace">Browse Marketplace</Button>
            </div>

            <!-- Content -->
            <div id="pageContent" class="hidden">
                <Tabs defaultValue="all">
                    <TabsList class="w-full justify-start bg-transparent border-b-2 border-border rounded-none mb-8 p-0">
                        <TabsTrigger value="all" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                            All
                            <span id="allCount" class="ml-1 text-xs bg-muted text-muted-foreground rounded-full px-2 py-0.5 font-bold">0</span>
                        </TabsTrigger>
                        <TabsTrigger value="purchases" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                            Purchases
                            <span id="purchaseCount" class="ml-1 text-xs bg-muted text-muted-foreground rounded-full px-2 py-0.5 font-bold">0</span>
                        </TabsTrigger>
                        <TabsTrigger value="sales" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                            Sales
                            <span id="saleCount" class="ml-1 text-xs bg-muted text-muted-foreground rounded-full px-2 py-0.5 font-bold">0</span>
                        </TabsTrigger>
                    </TabsList>

                    <!-- All Transactions -->
                    <TabsContent value="all">
                        <div id="allList" class="space-y-3"></div>
                    </TabsContent>

                    <!-- Purchases -->
                    <TabsContent value="purchases">
                        <div id="purchaseList" class="space-y-3"></div>
                        <p id="noPurchases" class="hidden text-muted-foreground text-center py-12">No purchases yet</p>
                    </TabsContent>

                    <!-- Sales -->
                    <TabsContent value="sales">
                        <div id="saleList" class="space-y-3"></div>
                        <p id="noSales" class="hidden text-muted-foreground text-center py-12">No sales yet</p>
                    </TabsContent>
                </Tabs>
            </div>

        </div>
    </div>
</Layout>

<script>
	import { supabase } from "../lib/supabase";
	import { fetchUserTransactions, timeAgo, type TransactionWithNames } from "../lib/api";
	
	const CATEGORY_GRADIENTS: Record<string, string> = {
		Books: "linear-gradient(135deg,#2d6a4f,#52b788)",
		Electronics: "linear-gradient(135deg,#1e3c72,#2a5298)",
		Furniture: "linear-gradient(135deg,#a0522d,#cd853f)",
		Clothing: "linear-gradient(135deg,#457b9d,#1d3557)",
		Misc: "linear-gradient(135deg,#ef476f,#f78c6b)",
	};
	
	const CATEGORY_ICONS: Record<string, string> = {
		Books: "\u{1F4D7}",
		Electronics: "\u{1F4BB}",
		Furniture: "\u{1FA91}",
		Clothing: "\u{1F9E5}",
		Misc: "\u{1F4E6}",
	};
	
	function escapeHtml(
		str: string
	): string {
		const div = document.createElement("div");
		div.textContent = str;
		return div.innerHTML;
	}
	
	function formatDate(
		dateString: string
	): string {
		const date = new Date(dateString);
		return date.toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		});
	}
	
	function formatCurrency(
		amount: number
	): string {
		return `$${amount.toFixed(2)}`;
	}
	
	function renderTransactionCard(
		transaction: TransactionWithNames,
		role: "buyer" | "seller"
	): string {
		const gradient = CATEGORY_GRADIENTS[transaction.category] || "linear-gradient(135deg,#6b7280,#9ca3af)";
		const icon = CATEGORY_ICONS[transaction.category] || "\u{1F4E6}";
		const hasImage = transaction.images && transaction.images.length > 0;
		const isCancelled = transaction.status === "cancelled";
		
		const otherName = role === "buyer" ? transaction.seller_name : (transaction.buyer_name || "Unknown Buyer");
		const otherLabel = role === "buyer" ? "Seller" : "Buyer";
		const otherInitials = (otherName || "?")
			.split(" ")
			.map((w: string) => w[0])
			.join("")
			.toUpperCase()
			.slice(0, 2);
		
		const roleBadge = role === "buyer"
			? `<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-blue-500/10 text-blue-600 border border-blue-200">Purchase</span>`
			: `<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-emerald-500/10 text-emerald-600 border border-emerald-200">Sale</span>`;
		
		const statusBadge = isCancelled
			? `<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-red-500/10 text-red-600 border border-red-200">Cancelled</span>`
			: `<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-green-500/10 text-green-600 border border-green-200">Completed</span>`;
		
		const priceColor = role === "buyer" ? "text-foreground" : "text-primary";
		
		return `
      <div class="bg-card rounded-xl border border-border overflow-hidden hover:border-primary/20 transition-colors ${isCancelled ? 'opacity-60' : ''}">
        <div class="flex items-stretch">
          <!-- Thumbnail -->
          <a href="/item?id=${transaction.listing_id}" class="shrink-0 w-20 sm:w-28 flex items-center justify-center" style="background: ${gradient}">
            ${hasImage
			? `<img src="${transaction.images[0]}" alt="${escapeHtml(transaction.title)}" class="w-full h-full object-cover" />`
			: `<span class="text-3xl">${icon}</span>`
		}
          </a>

          <!-- Details -->
          <div class="flex-1 p-4 flex flex-col sm:flex-row sm:items-center gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                ${roleBadge}
                ${statusBadge}
              </div>
              <a href="/item?id=${transaction.listing_id}" class="text-sm font-bold text-foreground hover:text-primary transition-colors no-underline line-clamp-1">
                ${escapeHtml(transaction.title)}
              </a>
              <div class="flex items-center gap-2 mt-1.5">
                <div class="w-5 h-5 rounded-full bg-primary/10 flex items-center justify-center text-[9px] font-bold text-primary">${otherInitials}</div>
                <span class="text-xs text-muted-foreground">
                  ${otherLabel}: <a href="/user?id=${role === "buyer" ? transaction.seller_id : (transaction.buyer_id || "")}" class="font-semibold text-foreground hover:text-primary no-underline">${escapeHtml(otherName)}</a>
                </span>
              </div>
            </div>

            <!-- Price & Date -->
            <div class="text-right shrink-0">
              <p class="text-lg font-extrabold ${transaction.price === 0 ? 'text-teal-600' : priceColor} ${isCancelled ? 'line-through' : ''}">${transaction.price === 0 ? 'FREE' : (role === "buyer" ? "-" : "+") + formatCurrency(transaction.price)}</p>
              <p class="text-xs text-muted-foreground mt-0.5">${formatDate(transaction.completed_at)}</p>
            </div>
          </div>
        </div>
      </div>
    `;
	}
	
	async function loadTransactions() {
		const { data: { user } } = await supabase.auth.getUser();
		if (!user) {
			window.location.href = "/login";
			return;
		}
		
		try {
			const transactions = await fetchUserTransactions(user.id);
			
			document.getElementById("loadingState")!.classList.add("hidden");
			
			if (transactions.length === 0) {
				document.getElementById("emptyState")!.classList.remove("hidden");
				return;
			}
			
			document.getElementById("pageContent")!.classList.remove("hidden");
			
			const purchases = transactions.filter((tx) => tx.buyer_id === user.id);
			const sales = transactions.filter((tx) => tx.seller_id === user.id);
			
			document.getElementById("allCount")!.textContent = transactions.length.toString();
			document.getElementById("purchaseCount")!.textContent = purchases.length.toString();
			document.getElementById("saleCount")!.textContent = sales.length.toString();
			
			const totalSpent = purchases
				.filter((tx) => tx.status === "completed")
				.reduce((sum, tx) => sum + tx.price, 0);
			const totalEarned = sales
				.filter((tx) => tx.status === "completed")
				.reduce((sum, tx) => sum + tx.price, 0);
			
			document.getElementById("totalSpent")!.textContent = formatCurrency(totalSpent);
			document.getElementById("totalEarned")!.textContent = formatCurrency(totalEarned);
			
			const allList = document.getElementById("allList")!;
			allList.innerHTML = transactions.map((tx) => {
				const role = tx.buyer_id === user.id ? "buyer" : "seller";
				return renderTransactionCard(tx, role);
			}).join("");
			
			const purchaseList = document.getElementById("purchaseList")!;
			if (purchases.length === 0) {
				document.getElementById("noPurchases")!.classList.remove("hidden");
			}
			else {
				purchaseList.innerHTML = purchases
					.map((tx) => renderTransactionCard(tx, "buyer"))
					.join("");
			}
			
			const saleList = document.getElementById("saleList")!;
			if (sales.length === 0) {
				document.getElementById("noSales")!.classList.remove("hidden");
			}
			else {
				saleList.innerHTML = sales
					.map((tx) => renderTransactionCard(tx, "seller"))
					.join("");
			}
			
		}
		catch (err) {
			console.error("Failed to load transactions:", err);
			document.getElementById("loadingState")!.classList.add("hidden");
			document.getElementById("emptyState")!.classList.remove("hidden");
		}
	}
	
	document.addEventListener("DOMContentLoaded", loadTransactions);
</script>