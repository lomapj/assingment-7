---
import Layout from "../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import Button from "@/components/starwind/button/Button.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import { Tabs, TabsList, TabsTrigger, TabsContent } from "@/components/starwind/tabs";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/starwind/table";
---

<Layout title="Moderation Panel">
  <div class="bg-muted min-h-screen pb-16">
    <!-- Hero -->
    <div class="bg-card border-b border-border py-8 md:py-12 relative overflow-hidden">
      <div class="absolute -top-1/2 -right-[10%] w-3/5 h-[200%] bg-radial-[circle] from-primary/5 to-transparent z-0"></div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-1">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div>
              <h1 class="text-3xl md:text-4xl font-extrabold text-foreground tracking-tight mb-1">Moderation Panel</h1>
              <p class="text-base text-muted-foreground">Manage reports, listings, and users</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="bg-card border-b border-border">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 py-4">
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center">
            <p class="text-2xl font-extrabold text-foreground" id="statPending">-</p>
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Pending Reports</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-extrabold text-foreground" id="statListings">-</p>
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Total Listings</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-extrabold text-foreground" id="statUsers">-</p>
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide">Registered Users</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading State -->
    <div id="modLoading" class="mx-auto max-w-7xl px-6 lg:px-8 mt-8">
      <div class="animate-pulse space-y-4">
        <div class="h-10 bg-muted rounded w-1/3"></div>
        <div class="h-64 bg-muted rounded-xl"></div>
      </div>
    </div>

    <!-- Access Denied State -->
    <div id="modDenied" class="hidden mx-auto max-w-7xl px-6 lg:px-8 mt-16 text-center">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-muted-foreground mb-4">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
      <h2 class="text-xl font-bold text-foreground mb-2">Access Denied</h2>
      <p class="text-muted-foreground mb-6">You don't have permission to access the moderation panel.</p>
      <Button variant="primary" href="/marketplace">Back to Marketplace</Button>
    </div>

    <!-- Main Content (hidden until loaded) -->
    <div id="modContent" class="hidden mx-auto max-w-7xl px-6 lg:px-8 mt-8">
      <Tabs defaultValue="reports">
        <TabsList class="w-full justify-start bg-transparent border-b-2 border-border rounded-none mb-8 p-0">
          <TabsTrigger value="reports" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
            Reports
            <span id="reportsBadge" class="hidden min-w-5 h-5 rounded-full bg-amber-400 text-foreground text-xs font-bold flex items-center justify-center">0</span>
          </TabsTrigger>
          <TabsTrigger value="listings" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Listings
          </TabsTrigger>
          <TabsTrigger value="users" class="gap-2 rounded-none border-b-2 border-transparent data-[state=active]:border-primary data-[state=active]:shadow-none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Users
          </TabsTrigger>
        </TabsList>

        <!-- Reports Tab -->
        <TabsContent value="reports" class="flex flex-col gap-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <h2 class="text-2xl font-extrabold text-foreground">Reports</h2>
            <div class="flex gap-2" id="reportFilterChips">
              <button class="report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-primary border-primary text-primary-foreground shadow-sm" data-filter="all">All</button>
              <button class="report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-card border-border text-muted-foreground hover:border-primary hover:text-primary" data-filter="pending">Pending</button>
              <button class="report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-card border-border text-muted-foreground hover:border-primary hover:text-primary" data-filter="resolved">Resolved</button>
              <button class="report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-card border-border text-muted-foreground hover:border-primary hover:text-primary" data-filter="dismissed">Dismissed</button>
            </div>
          </div>

          <div id="reportsEmpty" class="hidden text-center py-12">
            <p class="text-muted-foreground">No reports found.</p>
          </div>
          <div id="reportsList" class="space-y-4"></div>
        </TabsContent>

        <!-- Listings Tab -->
        <TabsContent value="listings" class="flex flex-col gap-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <h2 class="text-2xl font-extrabold text-foreground">All Listings</h2>
            <div class="relative flex-1 max-w-80">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
              <input type="text" id="listingSearch" placeholder="Search listings..." class="w-full py-2 pl-10 pr-4 rounded-full border border-border bg-card text-foreground text-sm outline-none focus:border-primary focus:ring-4 focus:ring-primary/10" />
            </div>
          </div>

          <div id="listingsTableWrap" class="hidden">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Item</TableHead>
                  <TableHead>Seller</TableHead>
                  <TableHead>Price</TableHead>
                  <TableHead>Status</TableHead>
                  <TableHead>Date</TableHead>
                  <TableHead class="text-right">Actions</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody id="listingsTableBody"></TableBody>
            </Table>
          </div>
          <div id="listingsEmptyAdmin" class="hidden text-center py-12">
            <p class="text-muted-foreground">No listings found.</p>
          </div>
        </TabsContent>

        <!-- Users Tab -->
        <TabsContent value="users" class="flex flex-col gap-6">
          <h2 class="text-2xl font-extrabold text-foreground">Registered Users</h2>

          <div id="usersTableWrap" class="hidden">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Name</TableHead>
                  <TableHead>Major</TableHead>
                  <TableHead>Graduation</TableHead>
                  <TableHead>Joined</TableHead>
                  <TableHead class="text-right">Actions</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody id="usersTableBody"></TableBody>
            </Table>
          </div>
          <div id="usersEmpty" class="hidden text-center py-12">
            <p class="text-muted-foreground">No users found.</p>
          </div>
        </TabsContent>
      </Tabs>
    </div>
  </div>

  <!-- Confirm Remove Dialog (vanilla HTML) -->
  <div id="confirmDialog" class="fixed inset-0 z-[999] hidden">
    <div class="fixed inset-0 bg-black/50" id="confirmOverlay"></div>
    <div class="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 bg-card rounded-xl border border-border shadow-xl p-6 w-full max-w-md z-10">
      <h3 class="text-lg font-bold text-foreground mb-2" id="confirmTitle">Confirm Action</h3>
      <p class="text-sm text-muted-foreground mb-6" id="confirmDesc">Are you sure?</p>
      <div class="flex justify-end gap-3">
        <button id="confirmCancel" class="px-4 py-2 rounded-lg border border-border text-sm font-semibold text-muted-foreground hover:bg-muted transition-colors">Cancel</button>
        <button id="confirmAction" class="px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-semibold hover:bg-red-700 transition-colors">Confirm</button>
      </div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase';
    import {
      checkIsAdmin,
      fetchAllReports,
      updateReportStatus,
      adminDeleteListing,
      fetchAllListings,
      fetchAllProfiles,
      deleteListingImages,
      timeAgo,
    } from '../lib/api';
    import type { ReportWithDetails, Listing, Profile } from '../lib/api';

    // ── State ───────────────────────────────────────────────────────
    let allReports: ReportWithDetails[] = [];
    let allListings: Listing[] = [];
    let allProfiles: Profile[] = [];
    let currentFilter = 'all';

    // ── Confirmation Dialog ─────────────────────────────────────────
    let pendingAction: (() => Promise<void>) | null = null;

    function showConfirm(title: string, desc: string, action: () => Promise<void>) {
      pendingAction = action;
      document.getElementById('confirmTitle')!.textContent = title;
      document.getElementById('confirmDesc')!.textContent = desc;
      document.getElementById('confirmDialog')!.classList.remove('hidden');
    }

    function hideConfirm() {
      document.getElementById('confirmDialog')!.classList.add('hidden');
      pendingAction = null;
    }

    document.getElementById('confirmCancel')!.addEventListener('click', hideConfirm);
    document.getElementById('confirmOverlay')!.addEventListener('click', hideConfirm);
    document.getElementById('confirmAction')!.addEventListener('click', async () => {
      if (pendingAction) {
        const btn = document.getElementById('confirmAction') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Processing...';
        try {
          await pendingAction();
        } catch (err) {
          console.error('Action failed:', err);
        }
        btn.disabled = false;
        btn.textContent = 'Confirm';
        hideConfirm();
      }
    });

    // ── Status badge helper ─────────────────────────────────────────
    function statusBadge(status: string): string {
      const colors: Record<string, string> = {
        pending: 'bg-amber-100 text-amber-800 border-amber-200',
        resolved: 'bg-green-100 text-green-800 border-green-200',
        dismissed: 'bg-gray-100 text-gray-600 border-gray-200',
        available: 'bg-green-100 text-green-800 border-green-200',
        sold: 'bg-blue-100 text-blue-800 border-blue-200',
      };
      const cls = colors[status] || 'bg-gray-100 text-gray-600 border-gray-200';
      return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border ${cls}">${status.charAt(0).toUpperCase() + status.slice(1)}</span>`;
    }

    // ── Render Reports ──────────────────────────────────────────────
    function renderReports() {
      const list = document.getElementById('reportsList')!;
      const empty = document.getElementById('reportsEmpty')!;
      const filtered = currentFilter === 'all'
        ? allReports
        : allReports.filter(r => r.status === currentFilter);

      if (filtered.length === 0) {
        list.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      list.innerHTML = filtered.map(r => `
        <div class="bg-card rounded-xl border border-border p-5 flex flex-col md:flex-row gap-4" data-report-id="${r.id}">
          <div class="flex gap-4 flex-1 min-w-0">
            ${r.listing_images.length > 0
              ? `<img src="${r.listing_images[0]}" alt="" class="w-16 h-16 rounded-lg object-cover shrink-0 border border-border" />`
              : `<div class="w-16 h-16 rounded-lg bg-muted flex items-center justify-center shrink-0"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted-foreground"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></div>`
            }
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                ${statusBadge(r.status)}
                <span class="text-xs text-muted-foreground">${timeAgo(r.created_at)}</span>
              </div>
              <a href="/item?id=${r.listing_id}" class="text-sm font-bold text-foreground hover:text-primary transition-colors line-clamp-1">${r.listing_title}</a>
              <p class="text-sm text-muted-foreground mt-1"><span class="font-semibold">Reason:</span> ${r.reason}</p>
              ${r.details ? `<p class="text-sm text-muted-foreground mt-0.5 line-clamp-2">${r.details}</p>` : ''}
              <p class="text-xs text-muted-foreground mt-1.5">Reported by <span class="font-semibold">${r.reporter_name}</span>${r.seller_name ? ` | Seller: <span class="font-semibold">${r.seller_name}</span>` : ''}</p>
            </div>
          </div>
          ${r.status === 'pending' ? `
            <div class="flex items-center gap-2 shrink-0">
              <button class="action-resolve px-3 py-1.5 rounded-lg bg-green-600 text-white text-xs font-bold hover:bg-green-700 transition-colors" data-id="${r.id}">Resolve</button>
              <button class="action-dismiss px-3 py-1.5 rounded-lg bg-gray-200 text-gray-700 text-xs font-bold hover:bg-gray-300 transition-colors" data-id="${r.id}">Dismiss</button>
              <button class="action-remove-listing px-3 py-1.5 rounded-lg bg-red-600 text-white text-xs font-bold hover:bg-red-700 transition-colors" data-id="${r.id}" data-listing-id="${r.listing_id}">Remove Listing</button>
            </div>
          ` : ''}
        </div>
      `).join('');
    }

    // ── Render Listings ─────────────────────────────────────────────
    function renderListings(filter = '') {
      const tbody = document.getElementById('listingsTableBody')!;
      const wrap = document.getElementById('listingsTableWrap')!;
      const empty = document.getElementById('listingsEmptyAdmin')!;

      const filtered = filter
        ? allListings.filter(l => l.title.toLowerCase().includes(filter.toLowerCase()))
        : allListings;

      if (filtered.length === 0) {
        wrap.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');
      wrap.classList.remove('hidden');

      tbody.innerHTML = filtered.map(l => `
        <tr class="border-b border-border hover:bg-muted/50 transition-colors">
          <td class="py-3 px-4">
            <div class="flex items-center gap-3">
              ${l.images && l.images.length > 0
                ? `<img src="${l.images[0]}" alt="" class="w-10 h-10 rounded-lg object-cover border border-border" />`
                : `<div class="w-10 h-10 rounded-lg bg-muted"></div>`
              }
              <a href="/item?id=${l.id}" class="text-sm font-semibold text-foreground hover:text-primary transition-colors line-clamp-1">${l.title}</a>
            </div>
          </td>
          <td class="py-3 px-4 text-sm text-muted-foreground">${l.seller_name ?? '—'}</td>
          <td class="py-3 px-4 text-sm font-bold text-foreground">$${Number(l.price).toFixed(2)}</td>
          <td class="py-3 px-4">${statusBadge(l.status)}</td>
          <td class="py-3 px-4 text-sm text-muted-foreground">${timeAgo(l.created_at)}</td>
          <td class="py-3 px-4 text-right">
            <button class="action-delete-listing px-3 py-1.5 rounded-lg bg-red-600 text-white text-xs font-bold hover:bg-red-700 transition-colors" data-listing-id="${l.id}">Remove</button>
          </td>
        </tr>
      `).join('');
    }

    // ── Render Users ────────────────────────────────────────────────
    function renderUsers() {
      const tbody = document.getElementById('usersTableBody')!;
      const wrap = document.getElementById('usersTableWrap')!;
      const empty = document.getElementById('usersEmpty')!;

      if (allProfiles.length === 0) {
        wrap.classList.add('hidden');
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');
      wrap.classList.remove('hidden');

      tbody.innerHTML = allProfiles.map(p => `
        <tr class="border-b border-border hover:bg-muted/50 transition-colors">
          <td class="py-3 px-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary">
                ${p.full_name ? p.full_name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2) : '?'}
              </div>
              <span class="text-sm font-semibold text-foreground">${p.full_name || 'Unnamed'}</span>
              ${p.is_admin ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.65rem] font-bold bg-primary/10 text-primary border border-primary/20">Admin</span>' : ''}
            </div>
          </td>
          <td class="py-3 px-4 text-sm text-muted-foreground">${p.major || '—'}</td>
          <td class="py-3 px-4 text-sm text-muted-foreground">${p.graduation_year ?? '—'}</td>
          <td class="py-3 px-4 text-sm text-muted-foreground">${timeAgo(p.created_at)}</td>
          <td class="py-3 px-4 text-right">
            <a href="/user?id=${p.id}" class="px-3 py-1.5 rounded-lg border border-border text-xs font-bold text-muted-foreground hover:border-primary hover:text-primary transition-colors inline-block no-underline">View Profile</a>
          </td>
        </tr>
      `).join('');
    }

    // ── Update Stats ────────────────────────────────────────────────
    function updateStats() {
      const pending = allReports.filter(r => r.status === 'pending').length;
      document.getElementById('statPending')!.textContent = pending.toString();
      document.getElementById('statListings')!.textContent = allListings.length.toString();
      document.getElementById('statUsers')!.textContent = allProfiles.length.toString();

      const badge = document.getElementById('reportsBadge')!;
      if (pending > 0) {
        badge.textContent = pending.toString();
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }

    // ── Event Delegation ────────────────────────────────────────────
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // Report filter chips
      const filterChip = target.closest('.report-filter-chip') as HTMLElement | null;
      if (filterChip) {
        currentFilter = filterChip.dataset.filter || 'all';
        document.querySelectorAll('.report-filter-chip').forEach(c => {
          c.className = 'report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-card border-border text-muted-foreground hover:border-primary hover:text-primary';
        });
        filterChip.className = 'report-filter-chip px-4 py-2 rounded-full border text-sm font-semibold transition-all bg-primary border-primary text-primary-foreground shadow-sm';
        renderReports();
        return;
      }

      // Resolve report
      const resolveBtn = target.closest('.action-resolve') as HTMLElement | null;
      if (resolveBtn) {
        const reportId = resolveBtn.dataset.id!;
        showConfirm('Resolve Report', 'Mark this report as resolved?', async () => {
          await updateReportStatus(reportId, 'resolved');
          const report = allReports.find(r => r.id === reportId);
          if (report) report.status = 'resolved';
          renderReports();
          updateStats();
        });
        return;
      }

      // Dismiss report
      const dismissBtn = target.closest('.action-dismiss') as HTMLElement | null;
      if (dismissBtn) {
        const reportId = dismissBtn.dataset.id!;
        showConfirm('Dismiss Report', 'Dismiss this report? The listing will remain active.', async () => {
          await updateReportStatus(reportId, 'dismissed');
          const report = allReports.find(r => r.id === reportId);
          if (report) report.status = 'dismissed';
          renderReports();
          updateStats();
        });
        return;
      }

      // Remove listing from report
      const removeFromReport = target.closest('.action-remove-listing') as HTMLElement | null;
      if (removeFromReport) {
        const reportId = removeFromReport.dataset.id!;
        const listingId = removeFromReport.dataset.listingId!;
        showConfirm('Remove Listing', 'This will permanently delete the reported listing and resolve the report. This cannot be undone.', async () => {
          const listing = allListings.find(l => l.id === listingId);
          if (listing?.images && listing.images.length > 0) {
            try { await deleteListingImages(listing.images); } catch (_) {}
          }
          await adminDeleteListing(listingId);
          await updateReportStatus(reportId, 'resolved');

          // Update local state
          const report = allReports.find(r => r.id === reportId);
          if (report) report.status = 'resolved';
          allListings = allListings.filter(l => l.id !== listingId);
          renderReports();
          renderListings();
          updateStats();
        });
        return;
      }

      // Delete listing from listings tab
      const deleteBtn = target.closest('.action-delete-listing') as HTMLElement | null;
      if (deleteBtn) {
        const listingId = deleteBtn.dataset.listingId!;
        showConfirm('Remove Listing', 'This will permanently delete this listing. This cannot be undone.', async () => {
          const listing = allListings.find(l => l.id === listingId);
          if (listing?.images && listing.images.length > 0) {
            try { await deleteListingImages(listing.images); } catch (_) {}
          }
          await adminDeleteListing(listingId);
          allListings = allListings.filter(l => l.id !== listingId);
          renderListings((document.getElementById('listingSearch') as HTMLInputElement).value);
          updateStats();
        });
        return;
      }
    });

    // Listing search
    document.getElementById('listingSearch')?.addEventListener('input', (e) => {
      renderListings((e.target as HTMLInputElement).value);
    });

    // ── Init ────────────────────────────────────────────────────────
    (async function init() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login';
        return;
      }

      const isAdmin = await checkIsAdmin(session.user.id);
      if (!isAdmin) {
        document.getElementById('modLoading')!.classList.add('hidden');
        document.getElementById('modDenied')!.classList.remove('hidden');
        return;
      }

      try {
        [allReports, allListings, allProfiles] = await Promise.all([
          fetchAllReports(),
          fetchAllListings(),
          fetchAllProfiles(),
        ]);

        updateStats();
        renderReports();
        renderListings();
        renderUsers();

        document.getElementById('modLoading')!.classList.add('hidden');
        document.getElementById('modContent')!.classList.remove('hidden');
      } catch (err) {
        console.error('Failed to load moderation data:', err);
        document.getElementById('modLoading')!.innerHTML = '<p class="text-red-500 text-center py-8">Failed to load data. Please try again.</p>';
      }
    })();
  </script>
</Layout>
